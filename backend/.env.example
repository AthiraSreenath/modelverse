# ── LLM Brain ────────────────────────────────────────────────────────────────
# Set ONE of these. Anthropic is checked first; OpenAI is the fallback.
# The visualizer, compute stats, and layer inspector work without any key.
# A key is only required for the chat panel.
#
# Get Anthropic key: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Get OpenAI key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Optional — raises HF API rate limit from ~100 req/day to ~1000 req/day.
# Get a token: https://huggingface.co/settings/tokens (read scope is enough)
HF_TOKEN=

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of extra allowed origins for the API.
# EXTRA_CORS_ORIGINS=https://your-domain.com
